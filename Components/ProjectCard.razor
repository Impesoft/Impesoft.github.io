<div class="project-card glass-card">
    <div class="project-meta">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-primary);">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
        </svg>
        @if (!string.IsNullOrEmpty(Link))
        {
            <a href="@Link" target="_blank" rel="noopener noreferrer" aria-label="View source on GitHub" style="color: var(--text-secondary);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
            </a>
        }
    </div>
    
    <h3>@Title</h3>
    <p class="project-desc">@Description</p>
    
    @if (Tech != null && Tech.Any())
    {
        <div class="project-tech">
            @foreach (var techItem in Tech)
            {
                <span class="tech-badge">@techItem</span>
            }
        </div>
    }
    
    @if (!string.IsNullOrEmpty(Link))
    {
        <a href="@Link" target="_blank" rel="noopener noreferrer" class="project-link">
            <span>View Source</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public IEnumerable<string> Tech { get; set; } = Array.Empty<string>();

    [Parameter]
    public string Link { get; set; } = string.Empty;
}
